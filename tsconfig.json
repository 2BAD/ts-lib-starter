{
  "extends": "@2bad/tsconfig",
  "include": ["source/**/*", "vitest.config.ts"],
  "compilerOptions": {
    "outDir": "build",
    "types": ["node"],
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "~/*": ["./source/*"]
    }
  }
}
